{
  "name": "mit-ocw-pipeline",
  "version": "0.1.0",
  "description": "MIT OCW course discovery, screening, and NotebookLM pipeline",
  "type": "module",
  "scripts": {
    "discover": "node src/scrape.js discover",
    "discover:test": "node src/scrape.js discover --query \"python\" --max 5 --headless --dry-run",
    "screen": "node src/scrape.js screen",
    "scrape": "node src/scrape.js",
    "status": "node src/scrape.js status",
    "shortlist": "node src/scrape.js shortlist",
    "similar": "node src/scrape.js similar",
    "local:import": "node src/scrape.js local import",
    "db:init": "node src/lib/db.js",
    "notebooklm:install": "python3 -m pip install \"notebooklm-py[browser]==0.3.4\"",
    "notebooklm:check": "notebooklm --version",
    "notebooklm:ready": "node src/scrape.js notebooklm ready",
    "notebooklm:export": "node src/scrape.js notebooklm export",
    "notebooklm:upload": "node src/scrape.js notebooklm upload",
    "notebooklm:sync": "node src/scrape.js notebooklm sync",
    "notebooklm:assets": "node src/scrape.js notebooklm assets",
    "test": "node --test test/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "crawlee": "^3.0.0",
    "playwright": "^1.40.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "better-sqlite3": "^9.0.0"
  }
}
